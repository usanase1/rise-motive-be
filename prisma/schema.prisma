generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}

// Report 

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  summary     String   @db.Text
  totalUsers  Int      @default(0)
  totalOrders Int      @default(0)
  totalTasks  Int      @default(0)
  totalServices Int    @default(0)
  createdAt   DateTime @default(now())
}

// ─── TASKERS ────────────────────────────────────────────────
model Tasker {
  id          Int              @id @default(autoincrement())
  name        String
  phone       String           @unique
  email       String?
  specialties String
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())

}

// ─── SERVICE REQUESTS (RM TaskSpot) ─────────────────────────
model EGovRequest {
  id             Int      @id @default(autoincrement())
  trackingCode   String   @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
   notifications  Notification[]
  service        String?
  description    String   @db.Text
  documentUrl    String?
  preferredDate  String?
  status         RequestStatus @default(PENDING)

  tasker         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ApplicationDocRequest {
  id             Int      @id @default(autoincrement())
  trackingCode   String   @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
  service        String?
  description    String   @db.Text
  documentUrl    String?
  preferredDate  String?
   notifications  Notification[]
  status         RequestStatus @default(PENDING)

  tasker         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CreativeMediaRequest {
  id             Int      @id @default(autoincrement())
  trackingCode   String   @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
  service        String?
  description    String   @db.Text
  documentUrl    String?
  preferredDate  String?
   notifications  Notification[]
  status         RequestStatus @default(PENDING)

  tasker         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}


model WebDigitalRequest {
  id             Int      @id @default(autoincrement())
  trackingCode   String   @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
  service        String?
  description    String   @db.Text
  documentUrl    String?
  preferredDate  String?
   notifications  Notification[]
  status         RequestStatus @default(PENDING)

  tasker         String?


  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LegalOfficialRequest {
  id             Int      @id @default(autoincrement())
  trackingCode   String   @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
  service        String?
  description    String   @db.Text
  documentUrl    String?
  preferredDate  String?
   notifications  Notification[]
  status         RequestStatus @default(PENDING)

  tasker         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id          Int      @id @default(autoincrement())

  title       String
  message     String
  type        String   // e.g. "NEW_REQUEST"

  isRead      Boolean  @default(false)

  adminId     Int?
  admin       Admin?   @relation(fields: [adminId], references: [id])

  egovId      Int?
  egov        EGovRequest? @relation(fields: [egovId], references: [id])

  appDocId    Int?
  appDoc      ApplicationDocRequest? @relation(fields: [appDocId], references: [id])

  creativeId  Int?
  creative    CreativeMediaRequest? @relation(fields: [creativeId], references: [id])

  webId       Int?
  web         WebDigitalRequest? @relation(fields: [webId], references: [id])

  legalId     Int?
  legal       LegalOfficialRequest? @relation(fields: [legalId], references: [id])

  createdAt   DateTime @default(now())
}



// ─── TRAINING APPLICATIONS (RM TaskSpot - Part II) ──────────
model TrainingApplication {
  id               Int              @id @default(autoincrement())
  fullName         String
  phone            String
  email            String?
  selectedCourse   TrainingCourse
  preferredSchedule String?
  experienceLevel  ExperienceLevel  @default(BEGINNER)
  status           ApplicationStatus @default(PENDING)
  createdAt        DateTime         @default(now())

  @@map("trainingapplication")
}

// ─── STATUS HISTORY (tracking timeline) ─────────────────────


// ─── PRODUCTS (RM ProSpot) ───────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  price       String?  // "Price on request" or actual price
  category    String
  imageUrl    String?
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())

  orders      Order[]
}

// ─── ORDERS (RM ProSpot) ─────────────────────────────────────
model Order {
  id            Int         @id @default(autoincrement())
  trackingCode  String      @unique
  customerName  String
  customerPhone String
  customerEmail String?
  address       String
  quantity      Int         @default(1)
  paymentMethod String?     // confirmed later via phone/VISA
  note          String?     @db.Text
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  productId     Int
  product       Product     @relation(fields: [productId], references: [id])
}

// ─── INFO POSTS (RM InfoSpot) ────────────────────────────────
model InfoPost {
  id          Int          @id @default(autoincrement())
  title       String
  description String       @db.Text
  category    InfoCategory
  deadline    String?
  location    String?
  applyLink   String?      // external link e.g. mifotra.gov.rw
  contactInfo String?      // e.g. "0795344768"
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

// ─── ENUMS ───────────────────────────────────────────────────



enum RequestStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum InfoCategory {
  JOB
  SCHOLARSHIP
  COMPETITION
  COMMUNITY
  ADVISORY
}

enum TrainingCourse {
  COMPUTER_FOUNDATIONS
  MICROSOFT_OFFICE
  GOOGLE_TOOLS
  E_GOVERNMENT_TOOLS
  DIGITAL_CONTENT_CREATION
  GRAPHIC_DESIGN
  AI_AND_DIGITAL_TOOLS
  BASIC_PROGRAMMING
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── ADMIN / STAFF ───────────────────────────────────────────
model Admin {
  id              Int       @id @default(autoincrement())
  fullName        String
  profilePicture  String?
  email           String    @unique
  password        String
   tokenBlacklists TokenBlacklist[]

  role            AdminRole @default(ADMIN)
  isActive        Boolean   @default(true)
  notifications   Notification[]

  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  adminId   Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin     Admin    @relation(fields: [adminId], references: [id])
}